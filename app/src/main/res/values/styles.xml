<resources>

    <style name="AppTheme" parent="Theme.AppCompat.Light.DarkActionBar">
        <item name="colorPrimary">@color/colorPrimary</item>
        <item name="colorPrimaryDark">@color/colorPrimaryDark</item>
        <item name="colorAccent">@color/colorAccent</item>
    </style>

    <style name="clickableView">
        <item name="android:foreground">?android:selectableItemBackground</item>
        <item name="android:background">?android:selectableItemBackground</item>
    </style>

    <style name="toolbar.btn" parent="clickableView">
        <item name="android:layout_width">@dimen/toolbar_height</item>
        <item name="android:layout_height">@dimen/toolbar_height</item>
        <item name="android:padding">@dimen/padding_default</item>
        <item name="android:layout_gravity">center_vertical</item>

    </style>

    <style name="AppTheme.Progress">
        <item name="colorPrimary">@color/txt_hint</item>
        <item name="colorAccent">@color/txt_hint</item>
        <item name="colorPrimaryDark">@color/txt_hint</item>
    </style>

    <!--
        ### List
    -->
    <style name="listItem" parent="clickableView">
        <item name="android:layout_width">match_parent</item>
        <item name="android:layout_height">wrap_content</item>
        <item name="android:paddingLeft">@dimen/padding_default</item>
        <item name="android:paddingRight">@dimen/padding_default</item>
        <item name="android:paddingTop">@dimen/padding_default</item>
        <item name="android:paddingBottom">@dimen/padding_default</item>
        <item name="android:gravity">center_vertical</item>
    </style>

    <style name="listItem.1Line">
        <item name="android:minHeight">@dimen/list_item_height</item>
    </style>

    <style name="listItem.2Line">
        <item name="android:minHeight">@dimen/list_item_height_2lines</item>
    </style>

    <!--
        ### Buttons
    -->
    <style name="btn">
        <item name="android:layout_width">wrap_content</item>
        <item name="android:textAllCaps">true</item>
        <item name="android:layout_height">@dimen/btn_height</item>
        <item name="android:minWidth">@dimen/btn_min_width</item>
        <item name="android:textSize">@dimen/txt_size_secondary</item>
        <item name="android:paddingLeft">@dimen/btn_padding</item>
        <item name="android:paddingRight">@dimen/btn_padding</item>
        <item name="android:textColor">@color/colorPrimaryAlt</item>
        <item name="android:background">@drawable/btn_raised_accent</item>
        <item name="android:clickable">true</item>
        <item name="android:gravity">center</item>
        <item name="android:layout_gravity">center_vertical</item>
    </style>

    <!-- Заполненняемая по ширине экрана кнопка  -->
    <style name="btn.filled">
        <item name="android:layout_width">match_parent</item>
        <item name="android:layout_marginLeft">@dimen/space_xs</item>
        <item name="android:layout_marginRight">@dimen/space_xs</item>
        <item name="android:height">@dimen/btn_height</item>
        <item name="android:textSize">@dimen/txt_size_button</item>
    </style>

    <!-- Заполненняемая по ширине экрана кнопка с фоном и закругленными краями -->
    <style name="btn.filled.accent">
        <item name="android:background">@drawable/btn_raised_accent</item>
        <item name="android:textColor">@color/colorPrimaryAlt</item>
    </style>


    <!--
        ### TextView
    -->
    <style name="txtSearch">
        <item name="android:layout_width">0dp</item>
        <item name="android:layout_weight">1</item>
        <item name="android:background">@null</item>
        <item name="android:gravity">left|center_vertical</item>
        <item name="android:paddingLeft">@dimen/padding_default</item>
        <item name="android:layout_margin">0dp</item>
        <item name="android:textSize">@dimen/txt_size_primary</item>
        <item name="android:textColor">@color/txt_primary</item>
        <item name="android:textColorHint">@color/txt_hint</item>
        <item name="android:imeOptions">actionSearch</item>
    </style>

    <style name="txtSearch.singleLine">
        <item name="android:layout_height">@dimen/toolbar_height</item>
        <item name="android:singleLine">true</item>
        <item name="android:lines">1</item>
    </style>

    <style name="txtTranslated">
        <item name="android:layout_width">0dp</item>
        <item name="android:layout_height">wrap_content</item>
        <item name="android:gravity">left|center_vertical</item>
        <item name="android:paddingLeft">@dimen/padding_default</item>
        <item name="android:layout_margin">@dimen/margin_default</item>
        <item name="android:textSize">@dimen/txt_size_large</item>
        <item name="android:textColor">@color/txt_primary</item>
    </style>

    <style name="btnFavorite">
        <item name="android:background">?android:attr/selectableItemBackgroundBorderless</item>
    </style>
</resources>
